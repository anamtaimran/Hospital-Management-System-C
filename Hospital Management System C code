#include <stdio.h>
#include <string.h>

int main()
{
    char names[100][50];
    int ages[100];
    char diseases[100][50];

    int n = 0;
    int choice;

    while(1)
    {
        printf("\n===== Hospital Management System =====\n");
        printf("1. Add a new patient\n");
        printf("2. Search for a patient\n");
        printf("3. Display all patients\n");
        printf("4. Exit\n");

        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch(choice)
        {
            case 1:

                if(n < 100)
                {
                    printf("\nEnter Patient Details:\n");

                    printf("Name: ");
                    scanf("%s", names[n]);

                    printf("Age: ");
                    scanf("%d", &ages[n]);

                    printf("Disease: ");
                    scanf("%s", diseases[n]);

                    n++;

                    printf("\nPatient added successfully!\n");
                }
                else
                {
                    printf("\nPatient limit reached!\n");
                }

                break;

            case 2:
            {
                char searchName[50];
                int found = 0;

                printf("\nEnter patient name to search: ");
                scanf("%s", searchName);

                for(int i = 0; i < n; i++)
                {
                    if(strcmp(names[i], searchName) == 0)
                    {
                        printf("\nPatient Found!\n");
                        printf("Name: %s\n", names[i]);
                        printf("Age: %d\n", ages[i]);
                        printf("Disease: %s\n", diseases[i]);

                        found = 1;
                        break;
                    }
                }

                if(found == 0)
                {
                    printf("\nPatient not found!\n");
                }

                break;
            }

            case 3:

                if(n == 0)
                {
                    printf("\nNo patients available!\n");
                }
                else
                {
                    printf("\n----- Patient Records -----\n");

                    for(int i = 0; i < n; i++)
                    {
                        printf("\nPatient %d\n", i + 1);
                        printf("Name    : %s\n", names[i]);
                        printf("Age     : %d\n", ages[i]);
                        printf("Disease : %s\n", diseases[i]);
                    }
                }

                break;

            case 4:

                printf("\nExiting Program...\n");
                return 0;

            default:

                printf("\nInvalid Choice!\n");
        }
    }

    return 0;
}
